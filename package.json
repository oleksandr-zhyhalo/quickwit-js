{
  "name": "quickwit-js",
  "version": "0.1.0",
  "description": "Lightweight TypeScript client for Quickwit search engine",
  "license": "MIT",
  "author": "Oleksandr Zhyhalo",
  "repository": {
    "type": "git",
    "url": "https://github.com/oleksandr-zhyhalo/quickwit-js.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/oleksandr-zhyhalo/quickwit-js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "quickwit",
    "search",
    "sdk",
    "typescript",
    "client"
  ],
  "scripts": {
    "build": "bun run build:esm && bun run build:cjs && bun run build:types",
    "build:esm": "bun build ./src/index.ts --outdir ./dist --target node",
    "build:cjs": "bun build ./src/index.ts --outfile ./dist/index.cjs --target node",
    "build:types": "tsc -p tsconfig.build.json && cp dist/index.d.ts dist/index.d.cts",
    "test": "bun test",
    "prepublishOnly": "bun run build && bun test"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}